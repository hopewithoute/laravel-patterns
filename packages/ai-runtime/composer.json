{
    "name": "labtime/ai-runtime",
    "description": "Engine-agnostic AI Runtime Kernel for Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Labtime\\AiRuntime\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Labtime\\AiRuntime\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Antigravity",
            "email": "antigravity@example.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/container": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/pipeline": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/ai": "^0.5.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Labtime\\AiRuntime\\AiRuntimeServiceProvider"
            ]
        }
    }
}
