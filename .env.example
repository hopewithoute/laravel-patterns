APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# AI Defaults
AI_PROVIDER=cliproxyapi
AI_IMAGE_PROVIDER=gemini
AI_AUDIO_PROVIDER=openai
AI_TRANSCRIPTION_PROVIDER=openai
AI_EMBEDDINGS_PROVIDER=openai
AI_RERANKING_PROVIDER=cohere
AI_MODEL=gpt-5.4-mini

# AI Providers
ANTHROPIC_API_KEY=
ANTHROPIC_URL=https://api.anthropic.com/v1

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_URL=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

COHERE_API_KEY=
DEEPSEEK_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_API_KEY=

GROQ_API_KEY=
GROQ_URL=https://api.groq.com/openai/v1

JINA_API_KEY=

MISTRAL_API_KEY=
MISTRAL_URL=https://api.mistral.ai/v1

OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

CLIPROXYAPI_API_KEY=
CLIPROXYAPI_URL=http://127.0.0.1:8317/v1
CLIPROXYAPI_MODEL=gpt-5.4-mini
CLIPROXYAPI_EMBEDDINGS_MODEL=text-embedding-3-small
CLIPROXYAPI_EMBEDDINGS_DIMENSIONS=1536

OPENAI_API_KEY=
OPENAI_URL=https://api.openai.com/v1

OPENROUTER_API_KEY=
VOYAGEAI_API_KEY=

XAI_API_KEY=
XAI_URL=https://api.x.ai/v1

# AI Runtime
AI_RUNTIME_LEXICAL_DRIVER=sqlite_fts5
AI_RUNTIME_LEXICAL_LANGUAGE=simple
AI_RUNTIME_TELEMETRY_DRIVER=database

AI_RUNTIME_STREAM_DRIVER=sse
AI_RUNTIME_STREAM_REDIS_CONNECTION=
AI_RUNTIME_STREAM_REDIS_PREFIX=ai-runtime
AI_RUNTIME_STREAM_MERCURE_TOPIC_PREFIX=ai-runtime
MERCURE_PUBLISH_URL=
MERCURE_SUBSCRIBE_URL=/.well-known/mercure
MERCURE_JWT=
# Legacy fallback for Mercure hub URL. Prefer MERCURE_PUBLISH_URL and MERCURE_SUBSCRIBE_URL.
# MERCURE_HUB_URL=

VITE_APP_NAME="${APP_NAME}"
